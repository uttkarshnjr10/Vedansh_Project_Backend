<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
</head>

<body style="margin:0;padding:0;background:#f4f7f6;font-family:Arial,sans-serif;">
    <table width="100%" style="max-width:600px;margin:20px auto;background:#fff;border-radius:12px;overflow:hidden;">
        <tr>
            <td style="background:linear-gradient(135deg,#c0392b,#e74c3c);padding:30px;text-align:center;">
                <h1 style="color:#fff;margin:0;">🌿 VanaAushadhi</h1>
                <p style="color:#fadbd8;">Order Cancelled</p>
            </td>
        </tr>
        <tr>
            <td style="padding:30px;">
                <p>Hi <strong>{{customerName}}</strong>,</p>
                <p>Your order <strong>#{{orderNumber}}</strong> has been cancelled.</p>
                <p><strong>Reason:</strong> {{cancellationReason}}</p>
                {{#if refundAmount}}<div
                    style="background:#fef9e7;padding:20px;border-radius:8px;margin:20px 0;border-left:4px solid #f39c12;">
                    <p style="margin:0;">💰 Refund of <strong>₹{{refundAmount}}</strong> will be credited to your
                        {{refundMethod}} within 2-5 business days.</p>
                </div>{{/if}}
            </td>
        </tr>
        <tr>
            <td style="background:#f4f7f6;padding:20px;text-align:center;color:#888;font-size:12px;">© 2025
                VanaAushadhi<br><a href="{{unsubscribeUrl}}" style="color:#888;">Unsubscribe</a></td>
        </tr>
    </table>
</body>

</html>