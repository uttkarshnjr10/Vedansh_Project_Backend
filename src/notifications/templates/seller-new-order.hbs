<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
</head>

<body style="margin:0;padding:0;background:#f4f7f6;font-family:Arial,sans-serif;">
    <table width="100%" style="max-width:600px;margin:20px auto;background:#fff;border-radius:12px;overflow:hidden;">
        <tr>
            <td style="background:linear-gradient(135deg,#2d8a4e,#1a6b38);padding:30px;text-align:center;">
                <h1 style="color:#fff;margin:0;">🌿 VanaAushadhi</h1>
                <p style="color:#d4edda;">New Order! 📦</p>
            </td>
        </tr>
        <tr>
            <td style="padding:30px;">
                <p>Hi <strong>{{sellerName}}</strong>,</p>
                <p>You have a new order! Order <strong>#{{orderNumber}}</strong></p>
                <div style="background:#f0f9f4;padding:20px;border-radius:8px;margin:20px 0;">
                    <p style="margin:0;">🛒 Items: <strong>{{itemCount}}</strong></p>
                    <p style="margin:8px 0 0;">💰 Your earnings: <strong>₹{{sellerAmount}}</strong></p>
                </div>
                <p>Please process this order within 48 hours.</p>
            </td>
        </tr>
        <tr>
            <td style="background:#f4f7f6;padding:20px;text-align:center;color:#888;font-size:12px;">© 2025 VanaAushadhi
            </td>
        </tr>
    </table>
</body>

</html>