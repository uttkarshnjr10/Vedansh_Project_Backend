<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
</head>

<body style="margin:0;padding:0;background:#f4f7f6;font-family:Arial,sans-serif;">
    <table width="100%" style="max-width:600px;margin:20px auto;background:#fff;border-radius:12px;overflow:hidden;">
        <tr>
            <td style="background:linear-gradient(135deg,#2d8a4e,#1a6b38);padding:30px;text-align:center;">
                <h1 style="color:#fff;margin:0;">🌿 VanaAushadhi</h1>
                <p style="color:#d4edda;">Order Delivered! ✅</p>
            </td>
        </tr>
        <tr>
            <td style="padding:30px;">
                <p>Hi <strong>{{customerName}}</strong>,</p>
                <p>Your order <strong>#{{orderNumber}}</strong> has been delivered successfully!</p>
                <p>We hope you love your products. Would you like to leave a review?</p>
                <div style="text-align:center;margin:20px 0;">
                    <a href="{{reviewUrl}}"
                        style="background:#2d8a4e;color:#fff;padding:12px 30px;border-radius:8px;text-decoration:none;font-weight:bold;">Write
                        a Review ⭐</a>
                </div>
                <p style="color:#888;">You earned <strong>{{loyaltyPointsEarned}} loyalty points</strong> from this
                    purchase!</p>
            </td>
        </tr>
        <tr>
            <td style="background:#f4f7f6;padding:20px;text-align:center;color:#888;font-size:12px;">© 2025
                VanaAushadhi<br><a href="{{unsubscribeUrl}}" style="color:#888;">Unsubscribe</a></td>
        </tr>
    </table>
</body>

</html>