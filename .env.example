# Application
NODE_ENV=development
PORT=3000
APP_NAME=VanaAushadhi
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001
ADMIN_URL=http://localhost:3002

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=vanaaushadhi_db
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# JWT
JWT_ACCESS_SECRET=your_jwt_access_secret_min_32_characters_long
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_characters_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# OTP
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_LOCKOUT_MINUTES=10

# AWS S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your_s3_bucket_name
AWS_CLOUDFRONT_URL=https://your-cloudfront-url.cloudfront.net

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# SMS (MSG91)
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=your_sender_id
MSG91_OTP_TEMPLATE_ID=your_template_id

# Email (AWS SES)
SES_REGION=ap-south-1
SES_FROM_EMAIL=noreply@yourdomain.com
SES_FROM_NAME=YourAppName

# Commission
DEFAULT_COMMISSION_RATE=15
MIN_COMMISSION_RATE=10
MAX_COMMISSION_RATE=25

# Loyalty Points
POINTS_PER_RUPEE=1
RUPEE_PER_POINT=0.25
MIN_POINTS_REDEEM=100

# Pagination
DEFAULT_PAGE_SIZE=24
MAX_PAGE_SIZE=100
